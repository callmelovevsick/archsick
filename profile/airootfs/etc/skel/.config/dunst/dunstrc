# ============================================================
# ArchSick dunst notification configuration
# Developer: lovevsick
# ============================================================

[global]
    monitor = 0
    follow = mouse
    width = 320
    height = 160
    origin = top-right
    offset = 12x12
    scale = 0
    notification_limit = 5

    progress_bar = true
    progress_bar_height = 4
    progress_bar_frame_width = 0
    progress_bar_min_width = 240
    progress_bar_max_width = 300

    indicate_hidden = yes
    shrink = no
    transparency = 10
    separator_height = 1
    padding = 10
    horizontal_padding = 14
    text_icon_padding = 10
    frame_width = 1
    frame_color = "#1e2531"
    separator_color = frame
    sort = yes
    idle_threshold = 120

    font = JetBrains Mono 10
    line_height = 0
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = center
    show_age_threshold = 60
    ellipsize = middle
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = yes

    icon_position = left
    min_icon_size = 0
    max_icon_size = 32
    icon_path = /usr/share/icons/hicolor/32x32/apps:/usr/share/icons/hicolor/32x32/status:/usr/share/pixmaps

    sticky_history = yes
    history_length = 20

    dmenu = /usr/bin/rofi -dmenu
    browser = /usr/bin/xdg-open
    always_run_script = true
    title = Dunst
    class = Dunst
    corner_radius = 8
    ignore_dbusclose = false

    force_xwayland = false
    force_xinerama = false

    mouse_left_click = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_all

[experimental]
    per_monitor_dpi = false

[urgency_low]
    background = "#161b22"
    foreground = "#a9b1d6"
    frame_color = "#1e2531"
    timeout = 4
    default_icon = dialog-information

[urgency_normal]
    background = "#161b22"
    foreground = "#c0caf5"
    frame_color = "#7dcfff"
    timeout = 6
    default_icon = dialog-information

[urgency_critical]
    background = "#161b22"
    foreground = "#f7768e"
    frame_color = "#f7768e"
    timeout = 0
    default_icon = dialog-error
