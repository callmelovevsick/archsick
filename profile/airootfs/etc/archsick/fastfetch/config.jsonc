{
    "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
    "logo": {
        "source": "/usr/share/archsick/ascii/logo.txt",
        "color": {
            "1": "cyan",
            "2": "blue"
        },
        "padding": {
            "right": 2
        }
    },
    "display": {
        "separator": "  ",
        "color": {
            "keys": "cyan",
            "title": "cyan",
            "separator": "blue"
        }
    },
    "modules": [
        {
            "type": "title",
            "format": "{user-name}@{host-name}"
        },
        "separator",
        {
            "type": "os",
            "key": "OS",
            "keyColor": "cyan"
        },
        {
            "type": "kernel",
            "key": "Kernel",
            "keyColor": "cyan"
        },
        {
            "type": "uptime",
            "key": "Uptime",
            "keyColor": "cyan"
        },
        {
            "type": "shell",
            "key": "Shell",
            "keyColor": "cyan"
        },
        {
            "type": "wm",
            "key": "WM",
            "keyColor": "cyan"
        },
        {
            "type": "theme",
            "key": "Theme",
            "keyColor": "cyan"
        },
        {
            "type": "icons",
            "key": "Icons",
            "keyColor": "cyan"
        },
        {
            "type": "terminal",
            "key": "Terminal",
            "keyColor": "cyan"
        },
        {
            "type": "cpu",
            "key": "CPU",
            "keyColor": "cyan",
            "showPeCoreCount": false
        },
        {
            "type": "gpu",
            "key": "GPU",
            "keyColor": "cyan",
            "detectionMethod": "pci"
        },
        {
            "type": "memory",
            "key": "Memory",
            "keyColor": "cyan"
        },
        {
            "type": "disk",
            "key": "Disk",
            "keyColor": "cyan"
        },
        "break",
        {
            "type": "colors",
            "paddingLeft": 0,
            "symbol": "circle"
        }
    ]
}
