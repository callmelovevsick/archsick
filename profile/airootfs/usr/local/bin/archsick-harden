#!/usr/bin/env bash
# ============================================================
# ArchSick Security Hardening Script
# Run post-install as root to apply security defaults
# Developer: lovevsick
# ============================================================
set -euo pipefail

GREEN='\033[0;32m'; YELLOW='\033[1;33m'; RED='\033[0;31m'; NC='\033[0m'
ok()   { echo -e "${GREEN}[✓]${NC} $*"; }
warn() { echo -e "${YELLOW}[!]${NC} $*"; }
err()  { echo -e "${RED}[✗]${NC} $*"; exit 1; }
info() { echo -e "    $*"; }

[[ $EUID -ne 0 ]] && err "Run as root"

echo "=== ArchSick Security Hardening ==="
echo

# ── UFW Firewall ─────────────────────────────────────────────
echo "--- Firewall (UFW) ---"
systemctl enable --now ufw
ufw default deny incoming
ufw default allow outgoing
ufw default deny forward
# Allow loopback
ufw allow in on lo
ufw deny in from 127.0.0.0/8
ufw deny in from ::1
# SSH (change port if needed)
ufw limit ssh comment "SSH rate limit"
ufw enable
ok "UFW firewall configured"

# ── Kernel hardening sysctl ───────────────────────────────────
echo "--- Kernel hardening ---"
cat > /etc/sysctl.d/90-archsick-security.conf << 'EOF'
# ArchSick kernel security hardening

# Disable IPv6 (optional, uncomment if not needed)
# net.ipv6.conf.all.disable_ipv6 = 1

# IP spoofing protection
net.ipv4.conf.default.rp_filter = 1
net.ipv4.conf.all.rp_filter = 1

# Ignore ICMP broadcast requests
net.ipv4.icmp_echo_ignore_broadcasts = 1

# Disable source packet routing
net.ipv4.conf.all.accept_source_route = 0
net.ipv4.conf.default.accept_source_route = 0

# Ignore send redirects
net.ipv4.conf.all.send_redirects = 0
net.ipv4.conf.default.send_redirects = 0

# Block SYN attacks
net.ipv4.tcp_syncookies = 1
net.ipv4.tcp_max_syn_backlog = 2048
net.ipv4.tcp_synack_retries = 2

# Log Martians
net.ipv4.conf.all.log_martians = 1
net.ipv4.conf.default.log_martians = 1

# Disable ICMP redirects
net.ipv4.conf.all.accept_redirects = 0
net.ipv4.conf.default.accept_redirects = 0

# Restrict dmesg to root
kernel.dmesg_restrict = 1

# Restrict kernel pointers
kernel.kptr_restrict = 2

# Restrict ptrace (breaks some debuggers - uncomment if fine with that)
# kernel.yama.ptrace_scope = 1

# Disable magic sysrq key (optional, useful for debugging)
kernel.sysrq = 16

# Prevent user namespaces (hardens, but breaks containers/flatpak - disable if using those)
# kernel.unprivileged_userns_clone = 0

# Enable ASLR
kernel.randomize_va_space = 2

# Restrict core dumps
fs.suid_dumpable = 0
kernel.core_uses_pid = 1

# Disable TCP SACK (optional - minor CVE mitigation)
# net.ipv4.tcp_sack = 0
EOF
sysctl -p /etc/sysctl.d/90-archsick-security.conf &>/dev/null
ok "Kernel security parameters applied"

# ── SSH hardening ─────────────────────────────────────────────
echo "--- SSH daemon hardening ---"
if [[ -f /etc/ssh/sshd_config ]]; then
    # Backup original
    cp /etc/ssh/sshd_config /etc/ssh/sshd_config.bak

    cat > /etc/ssh/sshd_config.d/archsick-security.conf << 'EOF'
# ArchSick SSH hardening
Protocol 2
PermitRootLogin no
PasswordAuthentication yes
PermitEmptyPasswords no
ChallengeResponseAuthentication no
MaxAuthTries 3
MaxSessions 5
X11Forwarding no
AllowTcpForwarding no
GatewayPorts no
PermitUserEnvironment no
AllowAgentForwarding no
IgnoreUserKnownHosts no
PrintLastLog yes
LoginGraceTime 30
ClientAliveInterval 300
ClientAliveCountMax 2
UsePAM yes
Ciphers chacha20-poly1305@openssh.com,aes256-gcm@openssh.com
MACs hmac-sha2-512-etm@openssh.com,hmac-sha2-256-etm@openssh.com
KexAlgorithms curve25519-sha256@libssh.org,diffie-hellman-group16-sha512
EOF
    ok "SSH daemon hardened"
else
    warn "sshd_config not found (SSH not installed)"
fi

# ── Fail2ban ──────────────────────────────────────────────────
echo "--- Fail2ban ---"
if command -v fail2ban-client &>/dev/null; then
    cat > /etc/fail2ban/jail.local << 'EOF'
[DEFAULT]
bantime  = 3600
findtime = 600
maxretry = 5
backend  = systemd

[sshd]
enabled  = true
port     = ssh
filter   = sshd
maxretry = 3
EOF
    systemctl enable --now fail2ban
    ok "Fail2ban enabled"
else
    warn "fail2ban not installed"
fi

# ── File permissions ──────────────────────────────────────────
echo "--- File permissions ---"
chmod 640 /etc/shadow
chmod 644 /etc/passwd
chmod 600 /etc/gshadow
chmod 644 /etc/group
# Remove world-writable SUID bits we don't need
chmod -s /usr/bin/wall 2>/dev/null || true
chmod -s /usr/bin/write 2>/dev/null || true
ok "Critical file permissions set"

# ── Core dump restriction ────────────────────────────────────
echo "--- Core dumps ---"
echo "* hard core 0" >> /etc/security/limits.conf
echo "* soft core 0" >> /etc/security/limits.conf
ok "Core dumps restricted"

# ── Disable unused network services ──────────────────────────
echo "--- Disabling unused services ---"
for svc in avahi-daemon cups-browsed; do
    systemctl disable --now "$svc" 2>/dev/null && ok "Disabled $svc" || true
done

# ── AppArmor ─────────────────────────────────────────────────
echo "--- AppArmor ---"
if systemctl is-active apparmor &>/dev/null; then
    ok "AppArmor already active"
elif command -v apparmor_status &>/dev/null; then
    systemctl enable --now apparmor
    ok "AppArmor enabled"
else
    warn "AppArmor not installed; install for additional confinement"
fi

# ── Summary ───────────────────────────────────────────────────
echo
echo "=== Security hardening complete ==="
echo
echo "Checklist:"
echo "  [✓] UFW firewall: default deny in, allow out"
echo "  [✓] Kernel hardening sysctl applied"
echo "  [✓] SSH daemon hardened"
echo "  [✓] Fail2ban (SSH)"
echo "  [✓] File permissions checked"
echo "  [✓] Core dumps disabled"
echo "  [✓] AppArmor (if available)"
echo
warn "Recommended manual steps:"
info "  - Disable SSH password auth and use keys: PasswordAuthentication no"
info "  - Change default SSH port if exposed to internet"
info "  - Enable full disk encryption (LUKS) at install time"
info "  - Review /etc/sysctl.d/90-archsick-security.conf for your use case"
info "  - Run 'sudo lynis audit system' for a full audit (install lynis first)"
